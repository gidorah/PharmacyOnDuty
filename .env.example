# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-value
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 eczanerede.com
CSRF_TRUSTED_ORIGINS=https://eczanerede.com https://www.eczanerede.com

# Google Maps (required in production)
GOOGLE_MAPS_API_KEY=
# Required in production — create a JavaScript/Vector Map ID in Google Cloud.
# Local/dev may omit this and fall back to DEMO_MAP_ID.
GOOGLE_MAPS_MAP_ID=
ALLOWED_REFERERS=https://eczanerede.com https://www.eczanerede.com

# Database (PostGIS)
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=db
DB_PORT=5432

# Redis / Celery
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://:CHANGE_ME@redis:6379/0

# Optional
SENTRY_DSN=
REMOTE_DEBUGGING_PORT=5678

# Production HTTPS (behind Coolify / TLS-terminating proxy)
DJANGO_ENABLE_SECURE_PROXY_SSL_HEADER=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False
