# Docker Compose interpolation defaults for scheduled validation runs.
# 127.0.0.1:0 asks Docker to allocate loopback-only ephemeral host ports,
# avoiding collisions while keeping container-to-container ports stable.
DJANGO_HOST_PORT=127.0.0.1:0
REMOTE_DEBUGGING_HOST_PORT=127.0.0.1:0
POSTGRES_HOST_PORT=127.0.0.1:0
REDIS_HOST_PORT=127.0.0.1:0
FLOWER_HOST_PORT=127.0.0.1:0
